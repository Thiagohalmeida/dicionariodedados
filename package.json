{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "prepare": "corepack pnpm exec husky install",
    "setup": "corepack pnpm install",
    "lint": "corepack pnpm exec prettier --check \"**/*.{js,ts,tsx,json,md}\"",
    "format": "corepack pnpm exec prettier --write \"**/*.{js,ts,tsx,json,md}\"",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "dev": "pnpm run dev:api & pnpm run dev:web",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:web": "pnpm --filter @workspace/data-dict run dev",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:studio": "pnpm --filter @workspace/db run studio"
  },
  "lint-staged": {
    "**/*.{js,ts,tsx,json,md}": [
      "corepack pnpm exec prettier --write"
    ]
  },
  "private": true,
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^14.0.0",
    "prettier": "^3.8.4",
    "typescript": "~5.9.3"
  },
  "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48"
}
