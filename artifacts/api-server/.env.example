# ============================================================================
# Validador de Dicionário de Dados - Configuração Local
# ============================================================================
#
# Copie este arquivo para .env e preencha os valores.
# NUNCA commit o arquivo .env no repositório!
#
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE (Obrigatório)
# ----------------------------------------------------------------------------
# Connection string do PostgreSQL
#
# Exemplos:
#   Local Docker:          postgresql://validador:validador@localhost:5432/validador
#   Supabase:             postgresql://postgres.xxxxxx:xxxxx@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#   Neon:                 postgresql://user:password@ep-xxx-xxx-xxx.us-east-1.aws.neon.tech/neondb
#
DATABASE_URL=postgresql://user:password@localhost:5432/validador

# ----------------------------------------------------------------------------
# SERVER (Opcional - defaults funcionam para desenvolvimento)
# ----------------------------------------------------------------------------
# Porta do servidor API (default: 5000)
PORT=5000

# Ambiente (development, production)
NODE_ENV=development

# Nível de log (debug, info, warn, error)
LOG_LEVEL=debug

# ----------------------------------------------------------------------------
# CORS (Opcional)
# ----------------------------------------------------------------------------
# Origens permitidas separadas por vírgula (para desenvolvimento local)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ----------------------------------------------------------------------------
# SESSION (Opcional - para futuras versões com autenticação)
# ----------------------------------------------------------------------------
# Secret para signing de sessões
# SESSION_SECRET=your-secret-key-here