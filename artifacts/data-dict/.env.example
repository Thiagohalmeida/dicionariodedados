# ============================================================================
# Validador de Dicionário de Dados - Configuração Frontend
# ============================================================================
#
# Copie este arquivo para .env.local e preencha os valores.
# Variáveis com prefixo VITE_ são expostas ao cliente (use apenas para URLs públicas).
# NUNCA commit arquivos .env no repositório!
#
# ============================================================================

# ----------------------------------------------------------------------------
# API CONFIG
# ----------------------------------------------------------------------------
# URL base da API (sem trailing slash)
# Para desenvolvimento local com proxy: não precisa configurar
# Para produção: URL do seu backend (Railway, Render, etc.)
# VITE_API_URL=https://api.seu-app.railway.app

# ----------------------------------------------------------------------------
# BASE PATH (Opcional - default: /)
# ----------------------------------------------------------------------------
# Define o caminho base da aplicação (para deploy em subpaths)
# BASE_PATH=/

# ----------------------------------------------------------------------------
# DEVELOPMENT
# ----------------------------------------------------------------------------
# Para desenvolvimento local, o Vite usa proxy no vite.config.ts
# pointing /api requests to http://localhost:5000
# Apenas mude VITE_API_PROXY_URL se sua API estiver em outra porta
# VITE_API_PROXY_URL=http://localhost:5000