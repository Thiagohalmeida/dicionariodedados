{
  "buildCommand": "pnpm --filter @workspace/data-dict run build",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "outputDirectory": "artifacts/data-dict/dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://validador-api-1lwu.onrender.com/api/$1"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
